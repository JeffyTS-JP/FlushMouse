<String Id="Caption" Value="[WixBundleName] Setup" />
	<String Id="Title" Value="[WixBundleName]" />
	<String Id="ConfirmCancelMessage" Value="セットアップを終了してもよろしいですか?" />

	<String Id="HelpHeader" Value="セットアップのヘルプ" />
	<String Id="HelpText" Value="/passive | /quiet&#xA;&#x9;最少の UI だけを表示してプロンプトは表示しないか、UIもプロンプトも表示しません。既定では、UI とすべてのプロンプトが表示されます。&#xA;&#xA;/norestart&#xA;&#x9;再起動の試みをすべて抑制します。既定では、再起動の前に UI によりプロンプトが表示されます。&#xA;&#xA;/log log.txt&#xA;&#x9;特定のファイルにログを記録します。既定では、%TEMP% にログ ファイルが作成されます。" />
	<String Id="HelpCloseButton" Value="閉じる(&amp;C)" />

